# ===========================================
# 1Herb Environment Variables
# ===========================================
# Copy this file to .env.local or .env and fill in your values
# NEVER commit .env files with real secrets to git!

# ===========================================
# Required - App Configuration
# ===========================================

# Public URL of your app (used for absolute URLs, sitemap, etc.)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# App name (shown in UI)
NEXT_PUBLIC_APP_NAME=1Herb

# ===========================================
# Required - Supabase (Database + Auth)
# ===========================================

# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Required - OpenRouter AI API
# ===========================================

# Get your key from: https://openrouter.ai/keys
# Used for the Virtual Herbalist chat feature
OPENROUTER_API_KEY=your-openrouter-key-here

# Model to use (default: free tier model)
# Free options: qwen/qwen3.6-plus:free, openrouter/free (auto-routes to free models)
# Paid options: openai/gpt-4o-mini, anthropic/claude-3-haiku, etc.
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# ===========================================
# Required - Stripe (Donations)
# ===========================================

# Get keys from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (from Stripe Dashboard > Webhooks)
# Required for donation confirmation
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# Optional - Rate Limiting (Production)
# ===========================================

# For serverless deployments, use Upstash Redis
# Get credentials from: https://upstash.com
RATE_LIMIT_BACKEND=upstash
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ===========================================
# Optional - Error Tracking (Sentry)
# ===========================================

# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# ===========================================
# Optional - Analytics (Vercel/Plausible)
# ===========================================

# Next.js built-in analytics (if deploying to Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=xxx

# Or Plausible (self-hosted or cloud)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# ===========================================
# Optional - External APIs
# ===========================================

# RxNorm API (defaults to public endpoint)
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# OpenFDA API (defaults to public endpoint)
OPENFDA_BASE_URL=https://api.fda.gov/drug

# ===========================================
# Deployment Specific
# ===========================================

# Set to 'true' on Render free tier to skip type checking (memory limit)
# RENDER=false

# Node environment (production/development/tesst)
# NODE_ENV=production